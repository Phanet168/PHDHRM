{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: artisan serve",
      "type": "shell",
      "command": "php",
      "args": ["artisan", "serve", "--host=127.0.0.1", "--port=8000"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "backend: npm dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "mobile: flutter pub get",
      "type": "shell",
      "command": "flutter",
      "args": ["pub", "get"],
      "options": {
        "cwd": "${workspaceFolder}/mobile"
      },
      "problemMatcher": []
    },
    {
      "label": "mobile: flutter run",
      "type": "shell",
      "command": "flutter",
      "args": ["run"],
      "options": {
        "cwd": "${workspaceFolder}/mobile"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "mobile: emulator launch Pixel_6_VIC",
      "type": "shell",
      "command": "C:/Users/Admin/AppData/Local/Android/Sdk/emulator/emulator.exe",
      "args": [
        "-avd",
        "Pixel_6_VIC",
        "-gpu",
        "swiftshader_indirect",
        "-no-boot-anim",
        "-camera-back",
        "none",
        "-camera-front",
        "none",
        "-noaudio"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "mobile: flutter run android",
      "type": "shell",
      "command": "flutter",
      "args": ["run", "-d", "emulator-5554"],
      "options": {
        "cwd": "${workspaceFolder}/mobile"
      },
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
